{
  "_comment": "AWS WAF Classic (v1) WebACL のエクスポート (遺品). WAF Classic は 2025-09-30 にサ終し、もう作れない。このルール一式を AWS WAF v2 で『同じ防御』として再現するのがこの問題=供養。各ルールの migrateTo が v2 への対応。",
  "_source": "aws waf-regional get-web-acl / get-rule / get-ip-set / get-sql-injection-match-set 相当の合成ダンプ",
  "WebACL": {
    "Name": "tenkacloud-profile-classic",
    "MetricName": "tenkacloudProfileClassic",
    "DefaultAction": { "Type": "ALLOW" }
  },
  "Rules": [
    {
      "Priority": 1,
      "Name": "block-bad-ips",
      "Action": { "Type": "BLOCK" },
      "Type": "REGULAR",
      "Predicates": [{ "Type": "IPMatch", "Negated": false, "DataId": "bad-ipset" }],
      "migrateTo": "WAFv2: IPSet + Statement.IPSetReferenceStatement, Action=Block (同じ CIDR を再現)"
    },
    {
      "Priority": 2,
      "Name": "block-sqli",
      "Action": { "Type": "BLOCK" },
      "Type": "REGULAR",
      "Predicates": [{ "Type": "SqlInjectionMatch", "Negated": false, "DataId": "sqli-body-qs" }],
      "migrateTo": "WAFv2: Statement.SqliMatchStatement (BODY + QUERY_STRING) もしくは AWSManagedRulesSQLiRuleSet"
    },
    {
      "Priority": 3,
      "Name": "rate-limit-2000",
      "Action": { "Type": "BLOCK" },
      "Type": "RATE_BASED",
      "RateKey": "IP",
      "RateLimit": 2000,
      "migrateTo": "WAFv2: Statement.RateBasedStatement { Limit: 2000, AggregateKeyType: IP }"
    }
  ],
  "Conditions": {
    "IPSet:bad-ipset": {
      "IPSetDescriptors": [
        { "Type": "IPV4", "Value": "203.0.113.0/24" },
        { "Type": "IPV4", "Value": "198.51.100.7/32" }
      ]
    },
    "SqlInjectionMatchSet:sqli-body-qs": {
      "SqlInjectionMatchTuples": [
        { "FieldToMatch": { "Type": "BODY" }, "TextTransformation": "URL_DECODE" },
        { "FieldToMatch": { "Type": "QUERY_STRING" }, "TextTransformation": "HTML_ENTITY_DECODE" }
      ]
    }
  }
}
